# Spendly Admin Panel Environment Variables
# Copy this file to .env.local inside admin-panel/ and fill in your values.

DATABASE_URL=postgresql://<user>:<password>@localhost:5432/spendly
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=5000

ADMIN_JWT_SECRET=<generate-a-32-byte-secret>
ADMIN_JWT_ACCESS_EXPIRY=3600
ADMIN_JWT_REFRESH_EXPIRY=86400

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001
ADMIN_PANEL_ORIGIN=http://localhost:3001